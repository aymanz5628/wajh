# Monorepo gitignore

# Dependencies
node_modules/
**/node_modules/

# Env files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
**/.env
**/.env.*

# Next.js build
.next/
**/.next/
out/
**/out/

# Strapi build & temp
.tmp/
**/.tmp/
.strapi/
**/.strapi/
dist/
**/dist/
build/
**/build/
.strapi-updater.json
.strapi-cloud.json
**/.strapi-updater.json
**/.strapi-cloud.json
public/uploads/*
!public/uploads/.gitkeep
**/public/uploads/*
!**/public/uploads/.gitkeep

# OS files
.DS_Store
Thumbs.db
*.log
**/*.log
